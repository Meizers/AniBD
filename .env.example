# Copiá este archivo a ".env" y ajustá si hace falta.

# Conexión a PostgreSQL (usuario:contraseña@host:puerto/base)
DATABASE_URL=postgres://anibd:anibd@localhost:5432/anibd

# Puerto del servidor web
PORT=3000

# Modo portable sin Docker: PostgreSQL embebido (PGlite). Tiene prioridad sobre
# DATABASE_URL. Es lo que usan AniBD.bat / "npm run lite".
# ANIBD_DB=pglite
# Carpeta de datos del modo pglite (default: la de datos del sistema, p.ej.
# ~/.local/share/anibd/pgdata o %APPDATA%\AniBD\pgdata).
# ANIBD_DATA_DIR=
