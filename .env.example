# Copiá este archivo a ".env" y ajustá si hace falta.

# Modo por defecto: PostgreSQL embebido (PGlite), sin Docker ni servidor aparte.
# Tiene prioridad sobre DATABASE_URL. Comentá esta línea si preferís un
# PostgreSQL real (ver "Opcional/avanzado" en el README).
ANIBD_DB=pglite

# Puerto del servidor web
PORT=3000

# Carpeta de datos del modo pglite (default: la de datos del sistema, p.ej.
# ~/.local/share/anibd/pgdata o %APPDATA%\AniBD\pgdata).
# ANIBD_DATA_DIR=

# Solo si comentaste ANIBD_DB=pglite arriba: conexión a un PostgreSQL real.
# DATABASE_URL=postgres://anibd:anibd@localhost:5432/anibd
